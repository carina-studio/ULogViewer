<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asControls="using:CarinaStudio.AppSuite.Controls"
        xmlns:asXaml="using:CarinaStudio.AppSuite.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CarinaStudio.ULogViewer.Controls.DequeueToVarEditorDialog"
        Name="dialog"
        Classes="Dialog"
        Title="{asXaml:StringResource DequeueToVarEditorDialog.Title}"
        Width="{DynamicResource Double/DequeueToVarEditorDialog.Width}">

	<DockPanel>

		<!-- Control buttons -->
		<Border Classes="Dialog_ControlButtonsPanel">
			<StackPanel Classes="Dialog_ControlButtonsPanel">
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #dialog.GenerateResultCommand}" Content="{Binding #dialog.OKButtonText}"/>
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #dialog.Close}" Content="{Binding #dialog.CancelButtonText}"/>
			</StackPanel>
		</Border>

		<!-- Content -->
		<StackPanel Classes="Dialog_ContentPanel">
			
			<!-- Queue -->
			<TextBlock Text="{asXaml:StringResource ContextualBasedAnalysisActionsEditorDialog.Queue}" asControls:DialogElement.TextRole="LabelAboveInputControl"/>
			<TextBox Name="queueTextBox" Classes="Dialog_TextBox" MaxLength="256"/>
			<Separator asControls:DialogElement.SeparatorType="Default"/>

			<!-- Variable -->
			<TextBlock Text="{asXaml:StringResource ContextualBasedAnalysisActionsEditorDialog.Variable}" asControls:DialogElement.TextRole="LabelAboveInputControl"/>
			<TextBox Name="varTextBox" Classes="Dialog_TextBox" MaxLength="256"/>
			
		</StackPanel>
		
	</DockPanel>
	
</Window>
