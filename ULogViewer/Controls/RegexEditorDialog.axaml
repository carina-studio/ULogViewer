<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="using:CarinaStudio.ULogViewer"
        xmlns:appControls="using:CarinaStudio.ULogViewer.Controls"
        xmlns:asControls="using:CarinaStudio.AppSuite.Controls"
        xmlns:asXaml="using:CarinaStudio.AppSuite.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CarinaStudio.ULogViewer.Controls.RegexEditorDialog"
        Classes="Dialog"
		Name="window"
        Title="{asXaml:StringResource RegexEditorDialog.Title}"
        Width="{DynamicResource Double/RegexEditorDialog.Width}">
	
	<!-- Content -->
	<DockPanel>

		<!-- Control buttons -->
		<Border Classes="Dialog_ControlButtonsPanel">
			<StackPanel Classes="Dialog_ControlButtonsPanel">
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.GenerateResultCommand}" Content="{Binding #window.OKButtonText}"/>
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.Close}" Content="{Binding #window.CancelButtonText}"/>
			</StackPanel>
		</Border>

		<!-- Content -->
		<ScrollViewer MaxHeight="{StaticResource Double/RegexEditorDialog.Content.MaxHeight}">
			<StackPanel Classes="Dialog_ContentPanel_WithItemsGroups">

				<!-- Regex -->
				<Border Classes="Dialog_ItemsGroup_Container">
					<StackPanel>

						<!-- Regex -->
						<asControls:DialogItem Name="regexItem">
							<StackPanel>
								<WrapPanel>
									<TextBlock Text="{asXaml:StringResource RegexEditorDialog.Regex}" asControls:DialogElement.TextRole="Label"/>
									<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.RegexReference}" ToolTip.Tip="{asXaml:StringResource Common.RegularExpression.Reference}">
										<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
									</Button>
								</WrapPanel>
								<TextBlock IsVisible="{Binding #regexTextBox.IsTextValid}" Text="{asXaml:StringResource RegexEditorDialog.Regex.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
								<TextBlock IsVisible="{Binding !#regexTextBox.IsTextValid}" Text="{asXaml:StringResource Common.InvalidFormat}" asControls:DialogElement.TextRole="ErrorDescriptionBelowLabel"/>
							</StackPanel>
						</asControls:DialogItem>
						<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
						<asControls:RegexTextBox Name="regexTextBox" Background="{x:Static Brushes.Transparent}" BorderBrush="{x:Static Brushes.Transparent}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" Height="{DynamicResource Double/RegexEditorDialog.RegexInput.Height}" IgnoreCase="False" asControls:DialogElement.IsDialogItemInput="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" TextAlignment="Left" TextWrapping="Wrap" Watermark="{asXaml:StringResource Common.Required}"/>
						<Separator asControls:DialogElement.SeparatorType="InnerItem" IsVisible="{Binding #window.IsCapturingGroupsEnabled}"/>
						<Panel IsVisible="{Binding #window.IsCapturingGroupsEnabled}">
							<SelectableTextBlock IsVisible="{Binding !#window.IsCapturingLogPropertiesEnabled}" Text="{asXaml:StringResource RegexEditorDialog.Regex.Description.CapturingGroups}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
							<SelectableTextBlock IsVisible="{Binding #window.IsCapturingLogPropertiesEnabled}" Text="{asXaml:StringResource RegexEditorDialog.Regex.Description.CapturingLogProperties}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
						</Panel>
						<Separator asControls:DialogElement.SeparatorType="Item"/>

						<!-- Ignore case -->
						<asControls:DialogItem ItemSize="Small">
							<TextBlock Text="{asXaml:StringResource RegexEditorDialog.IgnoreCase}" asControls:DialogElement.TextRole="Label"/>
							<ToggleSwitch IsChecked="{Binding #regexTextBox.IgnoreCase, Mode=TwoWay}" asControls:DialogElement.IsDialogItemInput="True"/>
						</asControls:DialogItem>
					
					</StackPanel>
				</Border>
				<Separator asControls:DialogElement.SeparatorType="Default"/>

				<!-- Test -->
				<Border Classes="Dialog_ItemsGroup_Container">
					<StackPanel>

						<!-- Test log line -->
						<asControls:DialogItem>
							<StackPanel>
								<TextBlock Text="{asXaml:StringResource RegexEditorDialog.TestLogLine}" asControls:DialogElement.TextRole="Label"/>
								<TextBlock Name="testLogLineDescriptionTextBlock" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
							</StackPanel>
						</asControls:DialogItem>
						<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
						<TextBox Name="testLogLineTextBox" Background="{x:Static Brushes.Transparent}" BorderBrush="{x:Static Brushes.Transparent}" Height="{DynamicResource Double/RegexEditorDialog.TestLogLine.Height}" asControls:DialogElement.IsDialogItemInput="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" Text="{Binding #window.TestLogLine, Mode=TwoWay}" TextAlignment="Left" TextWrapping="Wrap" Watermark="{asXaml:StringResource Common.None}"/>
						<Separator asControls:DialogElement.SeparatorType="Item"/>

						<!-- Test result -->
						<asControls:DialogItem ItemSize="Small">
							<TextBlock Text="{asXaml:StringResource RegexEditorDialog.TestResult}" asControls:DialogElement.TextRole="Label"/>
							<Panel>
								<Panel HorizontalAlignment="Right" IsVisible="{Binding #window.HasTestResult}" VerticalAlignment="Center">
									<TextBlock IsVisible="{Binding #window.TestResult}" Text="{asXaml:StringResource RegexEditorDialog.TestResult.Success}" asControls:DialogElement.TextRole="Default"/>
									<TextBlock Foreground="{DynamicResource Brush/Dialog.TextBlock.Foreground.Warning}" IsVisible="{Binding !#window.TestResult}" Text="{asXaml:StringResource RegexEditorDialog.TestResult.Failed}" asControls:DialogElement.TextRole="Default"/>
								</Panel>
								<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#window.HasTestResult}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
							</Panel>
						</asControls:DialogItem>

						<!-- Captured groups -->
						<StackPanel IsVisible="{Binding #window.IsCapturingGroupsEnabled}">
							<Separator asControls:DialogElement.SeparatorType="Item"/>
							<asControls:DialogItem ItemSize="Small">
								<Panel>
									<TextBlock IsVisible="{Binding !#window.IsCapturingLogPropertiesEnabled}" Text="{asXaml:StringResource RegexEditorDialog.TestResult.CapturedGroups}" asControls:DialogElement.TextRole="Label"/>
									<TextBlock IsVisible="{Binding #window.IsCapturingLogPropertiesEnabled}" Text="{asXaml:StringResource RegexEditorDialog.TestResult.CapturedLogProperties}" asControls:DialogElement.TextRole="Label"/>
								</Panel>
								<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#window.CapturedGroups.Count}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
							</asControls:DialogItem>
							<Separator IsVisible="{Binding #window.CapturedGroups.Count}" asControls:DialogElement.SeparatorType="InnerItem"/>
							<ListBox asControls:DialogElement.IsDialogItemInput="True" Grid.IsSharedSizeScope="True" IsVisible="{Binding #window.CapturedGroups.Count}" ItemsSource="{Binding #window.CapturedGroups}">
								<ListBox.ItemsPanel>
									<ItemsPanelTemplate>
										<StackPanel/>
									</ItemsPanelTemplate>
								</ListBox.ItemsPanel>
								<ListBox.ItemTemplate>
									<DataTemplate>
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition SharedSizeGroup="name" Width="Auto"/>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
											</Grid.ColumnDefinitions>
											<TextBlock HorizontalAlignment="Right" Text="{Binding Item1, StringFormat={}{0}:}" VerticalAlignment="Center"/>
											<Separator Grid.Column="1" asControls:DialogElement.SeparatorType="Small"/>
											<TextBlock Grid.Column="2" Text="{Binding Item2}" VerticalAlignment="Center"/>
										</Grid>
									</DataTemplate>
								</ListBox.ItemTemplate>
							</ListBox>
						</StackPanel>

					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>
		
	</DockPanel>
	
</Window>
