<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:abControls="using:CarinaStudio.Controls"
		xmlns:abConverters="using:CarinaStudio.Data.Converters"
        xmlns:appConverters="using:CarinaStudio.ULogViewer.Converters"
		xmlns:appProfiles="using:CarinaStudio.ULogViewer.Logs.Profiles"
        xmlns:appViewModels="using:CarinaStudio.ULogViewer.ViewModels"
		xmlns:asControls="using:CarinaStudio.AppSuite.Controls"
        xmlns:asXaml="using:CarinaStudio.AppSuite.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CarinaStudio.ULogViewer.Controls.VisibleLogPropertyEditorDialog"
        Name="window"
        Classes="Dialog"
		SizeToContent="Height"
        Title="{asXaml:StringResource VisibleLogPropertyEditorDialog.Title}"
        Width="{DynamicResource Double/VisibleLogPropertyEditorDialog.Width}">
	
	<Window.Styles>

		<Style Selector="ComboBox.Dialog_ComboBox /template/ ContentControl#ContentPresenter">
			<Setter Property="Grid.IsSharedSizeScope" Value="True"/>
		</Style>

	</Window.Styles>

	<DockPanel>

		<!-- Control buttons -->
		<Border Classes="Dialog_ControlButtonsPanel">
			<StackPanel Classes="Dialog_ControlButtonsPanel">
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.GenerateResultCommand}" Content="{Binding #window.OKButtonText}"/>
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.Close}" Content="{Binding #window.CancelButtonText}"/>
			</StackPanel>
		</Border>

		<!-- Content -->
		<StackPanel Classes="Dialog_ContentPanel_WithItemsGroups">
			<Border Classes="Dialog_ItemsGroup_Container">
				<StackPanel>

					<!-- Name -->
					<asControls:DialogItem>
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.Name}" asControls:DialogElement.TextRole="Label"/>
						<ComboBox Name="nameComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{Binding #window.LogPropertyNames}">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<Grid ColumnDefinitions="Auto,*">
										<TextBlock Text="{Binding Converter={x:Static appConverters:LogPropertyNameConverter.Default}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
										<abControls:FormattedTextBlock Arg1="{Binding}" Foreground="{DynamicResource Brush/Dialog.TextBlock.Foreground.Description}" Format="({0})" Grid.Column="1" HorizontalAlignment="Right" Margin="{StaticResource Thickness/VisibleLogPropertyEditorDialog.NameComboBox.Name.Margin}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
					
					<!-- Show defined log properties only -->
					<asControls:DialogItem ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.ShowDefinedLogPropertiesOnly}" asControls:DialogElement.TextRole="Label"/>
						<ToggleSwitch Name="showDefinedLogPropertiesOnlySwitch" IsChecked="True" asControls:DialogElement.IsDialogItemInput="True"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>

					<!-- Display name -->
					<asControls:DialogItem>
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.DisplayName}" asControls:DialogElement.TextRole="Label"/>
						<Panel HorizontalAlignment="Stretch">
							<ComboBox Name="displayNameComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding !#customDisplayNameSwitch.IsChecked}" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{x:Static appViewModels:DisplayableLogProperty.DisplayNames}">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<Grid ColumnDefinitions="Auto,*">
											<TextBlock Text="{Binding Converter={x:Static appConverters:LogPropertyNameConverter.Default}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
											<abControls:FormattedTextBlock Arg1="{Binding}" Foreground="{DynamicResource Brush/Dialog.TextBlock.Foreground.Description}" Format="({0})" Grid.Column="1" HorizontalAlignment="Right" Margin="{StaticResource Thickness/VisibleLogPropertyEditorDialog.NameComboBox.Name.Margin}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
										</Grid>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<TextBox Name="customDisplayNameTextBox" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #customDisplayNameSwitch.IsChecked}" MaxLength="256" PropertyChanged="OnEditorControlPropertyChanged" Watermark="{asXaml:StringResource Common.None}"/>
						</Panel>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="InnerItem"/>

					<!-- Custom display name -->
					<asControls:DialogItem ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.CustomDisplayName}" asControls:DialogElement.TextRole="Label"/>
						<ToggleSwitch Name="customDisplayNameSwitch" asControls:DialogElement.IsDialogItemInput="True" PropertyChanged="OnEditorControlPropertyChanged"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>
					
					<!-- Secondary display name -->
					<asControls:DialogItem ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.SecondaryDisplayName}" asControls:DialogElement.TextRole="Label"/>
						<TextBox Name="secondaryDisplayNameTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource Common.None}"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>
					
					<!-- Quantifier -->
					<asControls:DialogItem>
						<StackPanel Classes="Dialog_Item_Text_Container">
							<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.Quantifier}" asControls:DialogElement.TextRole="Label"/>
							<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.Quantifier.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
						</StackPanel>
						<TextBox Name="quantifierTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="32" Watermark="{asXaml:StringResource Common.None}"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>

					<!-- Foreground color -->
					<StackPanel IsVisible="{Binding #nameComboBox.SelectedItem, Converter={x:Static abConverters:ObjectConverters.IsNotEquivalentTo}, ConverterParameter=Level}">
						<asControls:DialogItem>
							<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.ForegroundColor}" asControls:DialogElement.TextRole="Label"/>
							<asControls:EnumComboBox Name="foregroundColorComboBox" EnumType="{x:Type appProfiles:LogPropertyForegroundColor}" asControls:DialogElement.IsDialogItemInput="True"/>
						</asControls:DialogItem>
						<Separator asControls:DialogElement.SeparatorType="Item"/>
					</StackPanel>

					<!-- Width -->
					<asControls:DialogItem ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.SpecifyWidth}" asControls:DialogElement.TextRole="Label"/>
						<ToggleSwitch Name="specifyWidthSwitch" asControls:DialogElement.IsDialogItemInput="True"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>
					<asControls:DialogItem>
						<StackPanel>
							<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.Width}" asControls:DialogElement.TextRole="Label"/>
							<TextBlock Text="{asXaml:StringResource VisibleLogPropertyEditorDialog.Width.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
						</StackPanel>
						<abControls:IntegerTextBox Name="widthTextBox" asControls:DialogElement.IsDialogItemInput="True" IsEnabled="{Binding #specifyWidthSwitch.IsChecked}" IsNullValueAllowed="False"/>
					</asControls:DialogItem>

				</StackPanel>
			</Border>
		</StackPanel>
		
	</DockPanel>
  
</Window>
