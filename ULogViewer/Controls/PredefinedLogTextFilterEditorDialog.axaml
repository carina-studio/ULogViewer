<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="using:CarinaStudio.ULogViewer"
        xmlns:appControls="using:CarinaStudio.ULogViewer.Controls"
        xmlns:appViewModels="using:CarinaStudio.ULogViewer.ViewModels"
        xmlns:asControls="using:CarinaStudio.AppSuite.Controls"
        xmlns:asXaml="using:CarinaStudio.AppSuite.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CarinaStudio.ULogViewer.Controls.PredefinedLogTextFilterEditorDialog"
        Name="window"
        Classes="Dialog"
		Icon="/ULogViewer.ico"
		ShowInTaskbar="True"
        Width="{DynamicResource Double/PredefinedLogTextFilterEditorDialog.Width}">
	
	<Window.Resources>
		<ContextMenu x:Key="groupNameSelectionMenu" Placement="Bottom"/>
	</Window.Resources>
	
	<Grid RowDefinitions="*,Auto">

		<!-- Content -->
		<Panel Classes="Dialog_ContentPanel_WithItemsGroups">
			<Border Classes="Dialog_ItemsGroup_Container">
				<StackPanel>

					<!-- Name -->
					<asControls:DialogItem Name="nameItem" ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.Name}" asControls:DialogElement.TextRole="Label"/>
						<TextBox Name="nameTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource Common.Required}"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Item"/>
					
					<!-- Group -->
					<asControls:DialogItem Name="groupNameItemContainer" ItemSize="Small">
						<TextBlock Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.GroupName}" asControls:DialogElement.TextRole="Label"/>
						<TextBox Name="groupNameTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="64" Watermark="{asXaml:StringResource Common.None}"/>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="Default"/>
					<ToggleButton Name="selectGroupNameButton" Command="{Binding #window.ShowGroupNameSelectionMenu}" asControls:DialogElement.IsDialogItemInput="True" IsEnabled="{Binding Groups.Count, Source={x:Static appViewModels:PredefinedLogTextFilterManager.Default}}">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock Classes="Button_Text" Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.SelectGroupName}"/>
							<Image Classes="Button_DropDownIcon" Grid.Column="1" IsVisible="{Binding !$parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.DropDown.Down}"/>
							<Image Classes="Button_DropDownIcon" Grid.Column="1" IsVisible="{Binding $parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.DropDown.Down.Light}"/>
						</Grid>
					</ToggleButton>
					<Separator asControls:DialogElement.SeparatorType="Item"/>

					<!-- Pattern -->
					<asControls:DialogItem Name="patternItem">
						<StackPanel>
							<WrapPanel>
								<TextBlock Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.Regex}" asControls:DialogElement.TextRole="Label"/>
								<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.RegexReference}" ToolTip.Tip="{asXaml:StringResource Common.RegularExpression.Reference}">
									<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
								</Button>
							</WrapPanel>
							<TextBlock IsVisible="{Binding #patternEditor.IsPatternTextValid}" Text="{asXaml:StringResource RegexEditorDialog.Regex.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
							<TextBlock IsVisible="{Binding !#patternEditor.IsPatternTextValid}" Text="{asXaml:StringResource Common.InvalidFormat}" asControls:DialogElement.TextRole="ErrorDescriptionBelowLabel"/>
						</StackPanel>
					</asControls:DialogItem>
					<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
					<appControls:PatternEditor Name="patternEditor" IsPhraseInputAssistanceEnabled="True" MinHeight="{DynamicResource Double/PredefinedLogTextFilterEditorDialog.RegexInput.Height}" Watermark="{asXaml:StringResource Common.Required}"/>
					<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
					<SelectableTextBlock Text="{asXaml:StringResource DisplayableLogAnalysisRuleEditorDialog.Pattern.Description.Detailed}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
					<Separator asControls:DialogElement.SeparatorType="Item"/>
					
					<!-- Mode -->
					<asControls:DialogItem>
						<StackPanel>
							<TextBlock Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.Mode.Exclusion}" asControls:DialogElement.TextRole="Label"/>
							<TextBlock Text="{asXaml:StringResource PredefinedLogTextFilterEditorDialog.Mode.Exclusion.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
						</StackPanel>
						<ToggleSwitch Name="exclusiveModeSwitch" asControls:DialogElement.IsDialogItemInput="True"/>
					</asControls:DialogItem>
					
				</StackPanel>
			</Border>
		</Panel>

		<!-- Control buttons -->
		<Border Classes="Dialog_ControlButtonsPanel" Grid.Row="1">
			<StackPanel Classes="Dialog_ControlButtonsPanel">
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.CompleteEditing}" Content="{Binding #window.OKButtonText}"/>
				<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.Close}" Content="{Binding #window.CancelButtonText}"/>
			</StackPanel>
		</Border>
		
	</Grid>
  
</Window>
