<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ia="using:Avalonia.Xaml.Interactivity"
        xmlns:iaCore="using:Avalonia.Xaml.Interactions.Core"
		xmlns:abControls="using:CarinaStudio.Controls"
        xmlns:abConverters="using:CarinaStudio.Data.Converters"
        xmlns:app="clr-namespace:CarinaStudio.ULogViewer;assembly=ULogViewer"
		xmlns:appCategorizing="using:CarinaStudio.ULogViewer.ViewModels.Categorizing"
        xmlns:appControls="clr-namespace:CarinaStudio.ULogViewer.Controls;assembly=ULogViewer"
        xmlns:appConverters="clr-namespace:CarinaStudio.ULogViewer.Converters;assembly=ULogViewer"
        xmlns:appLogProfiles="clr-namespace:CarinaStudio.ULogViewer.Logs.Profiles;assembly=ULogViewer"
        xmlns:appLogs="clr-namespace:CarinaStudio.ULogViewer.Logs;assembly=ULogViewer"
        xmlns:asControls="using:CarinaStudio.AppSuite.Controls"
        xmlns:asXaml="using:CarinaStudio.AppSuite.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CarinaStudio.ULogViewer.Controls.LogProfileEditorDialog"
        CanResize="True"
        Classes="Dialog"
        MinHeight="{StaticResource Double/LogProfileEditorDialog.MinHeight}"
        MinWidth="{StaticResource Double/LogProfileEditorDialog.MinWidth}"
		Name="window"
        SizeToContent="Manual"
        Width="{DynamicResource Double/LogProfileEditorDialog.Width}">

	<!-- Styles -->
	<Window.Styles>
		<Style Selector="ListBox">
			<Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
		</Style>
		<Style Selector="ListBoxItem">
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="Padding" Value="{DynamicResource Thickness/Dialog.ListBox.Item.WithInPlaceActions.Padding}"/>
		</Style>
	</Window.Styles>

	<!-- Content -->
	<DockPanel>

		<!-- Control buttons -->
		<Border Classes="Dialog_ControlButtonsPanel" DockPanel.Dock="Bottom">
			<Grid Classes="Dialog_ControlButtonsPanel" ColumnDefinitions="Auto,*">
				<StackPanel Classes="Dialog_ControlButtonsPanel">
					<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.OpenDocumentation}" Content="{Binding #window.HelpButtonText}"/>
					<Separator asControls:DialogElement.SeparatorType="ControlButton"/>
				</StackPanel>
				<StackPanel Classes="Dialog_ControlButtonsPanel" Grid.Column="1">
					<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.GenerateResultCommand}" Content="{Binding #window.OKButtonText}"/>
					<Button asControls:DialogElement.ButtonRole="Control" Command="{Binding #window.Close}" Content="{Binding #window.CancelButtonText}"/>
				</StackPanel>
			</Grid>
		</Border>
		
		<!-- Navigation bar -->
		<Border Classes="Toolbar" BorderBrush="{DynamicResource Brush/Toolbar.Border}" BorderThickness="0,0,1,0" DockPanel.Dock="Left">
			<asControls:ToolBarScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
				<StackPanel>
					
					<!-- Common -->
					<ToggleButton Name="commonPanelButton" asControls:ToolbarElement.Role="Button" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.Common}">
						<Panel>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding !$parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Settings.Outline}"/>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding $parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Settings.Outline.Light}"/>
						</Panel>
					</ToggleButton>
					
					<!-- Log reading -->
					<ToggleButton Name="logReadingPanelButton" asControls:ToolbarElement.Role="Button" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.LogReading}">
						<Panel>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding !$parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Import}"/>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding $parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Import.Light}"/>
						</Panel>
					</ToggleButton>
					
					<!-- Log displaying -->
					<ToggleButton Name="logDisplayingPanelButton" asControls:ToolbarElement.Role="Button" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.LogDisplaying}">
						<Panel>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding !$parent[ToggleButton].IsChecked}" Source="{StaticResource Image/Screen.Outline}"/>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding $parent[ToggleButton].IsChecked}" Source="{StaticResource Image/Screen.Outline.Light}"/>
						</Panel>
					</ToggleButton>
					
					<!-- Log writing -->
					<ToggleButton Name="logWritingPanelButton" asControls:ToolbarElement.Role="Button" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.LogWriting}">
						<Panel>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding !$parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Export}"/>
							<Image Classes="Toolbar_Icon" IsVisible="{Binding $parent[ToggleButton].IsChecked}" Source="{DynamicResource Image/Icon.Export.Light}"/>
						</Panel>
					</ToggleButton>
					
				</StackPanel>
			</asControls:ToolBarScrollViewer>
		</Border>

		<!-- Content -->
		<Panel>
			<ScrollViewer Name="baseScrollViewer" Classes="Dialog_ContentPanel" HorizontalScrollBarVisibility="Disabled">
				<StackPanel Classes="Dialog_ContentPanel_WithItemsGroups">

					<!-- Common -->
					<StackPanel Name="commonPanel">
						<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.Common}" asControls:DialogElement.TextRole="ItemsGroupHeader"/>
						<Border Classes="Dialog_ItemsGroup_Container">
							<StackPanel>
						
								<!-- Name -->
								<asControls:DialogItem Name="nameItem" ItemSize="Small">
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.Name}" asControls:DialogElement.TextRole="Label"/>
									<TextBox Name="nameTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" PropertyChanged="OnEditorControlPropertyChanged" Watermark="{asXaml:StringResource Common.Required}"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Description -->
								<asControls:DialogItem ItemSize="Small">
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.Description}" asControls:DialogElement.TextRole="Label"/>
									<TextBox Name="descriptionTextBox" asControls:DialogElement.IsDialogItemInput="True" MaxLength="1024" Watermark="{asXaml:StringResource Common.None}"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Icon -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.Icon}" asControls:DialogElement.TextRole="Label"/>
									<appControls:LogProfileIconComboBox Name="iconComboBox" IconColor="{Binding #iconColorComboBox.SelectedItem}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Icon color -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IconColor}" asControls:DialogElement.TextRole="Label"/>
									<appControls:LogProfileIconColorComboBox Name="iconColorComboBox" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Is template -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IsTemplate}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IsTemplate.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<ToggleSwitch Name="isTemplateSwitch" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								
							</StackPanel>
						</Border>
						<Separator asControls:DialogElement.SeparatorType="Large"/>
					</StackPanel>

					<!-- Log reading -->
					<StackPanel Name="logReadingPanel">
						<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogReading}" asControls:DialogElement.TextRole="ItemsGroupHeader"/>
						<Border Classes="Dialog_ItemsGroup_Container">
							<StackPanel>

								<!-- DataSource -->
								<StackPanel Name="dataSourceProviderContainer">
									<asControls:DialogItem>
										<StackPanel>
											<WrapPanel>
												<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.DataSourceProvider}" asControls:DialogElement.TextRole="Label"/>
												<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.LogDataSourcesDocument}" ToolTip.Tip="{asXaml:StringResource Common.Help}">
													<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
												</Button>
											</WrapPanel>
											<TextBlock Name="proVersionOnlyDataSourceProvider" Classes="Dialog_TextBlock_Description_Warning" IsVisible="{asXaml:AndBindings {Binding !#window.IsProVersionActivated}, {Binding #dataSourceProviderComboBox.SelectedItem.IsProVersionOnly, FallbackValue=False}}" Text="{asXaml:StringResource LogProfileEditorDialog.ProVersionOnly}"/>
											<TextBlock IsVisible="{asXaml:AndBindings {Binding !#window.IsValidDataSourceOptions}, {Binding !#proVersionOnlyDataSourceProvider.IsVisible}}" Text="{asXaml:StringResource LogProfileEditorDialog.InvalidDataSourceOptions}" asControls:DialogElement.TextRole="ErrorDescriptionBelowLabel"/>
										</StackPanel>
										<ComboBox Name="dataSourceProviderComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{Binding #window.DataSourceProviders}" VerticalAlignment="Center">
											<ComboBox.ItemTemplate>
												<DataTemplate>
													<Grid ColumnDefinitions="Auto,Auto,Auto,*">
														<Panel Classes="ComboBoxItem_Icon">
															<Image Classes="Icon" IsVisible="{Binding $parent[ComboBoxItem].IsSelected}" Source="{Binding Converter={x:Static appConverters:LogDataSourceProviderIconConverter.Default}, ConverterParameter=Light}"/>
															<Image Classes="Icon" IsVisible="{Binding !$parent[ComboBoxItem].IsSelected}" Source="{Binding Converter={x:Static appConverters:LogDataSourceProviderIconConverter.Default}}"/>
														</Panel>
														<TextBlock Classes="ComboBoxItem_TextBlock" Text="{Binding DisplayName}" Grid.Column="1"/>
														<Separator Grid.Column="2" IsVisible="{Binding #proVersionOnly.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
														<TextBlock Classes="ComboBoxItem_TextBlock" 
														           Name="proVersionOnly" 
														           Grid.Column="3" 
														           IsVisible="{asXaml:AndBindings {Binding !#window.IsProVersionActivated}, {Binding IsProVersionOnly}}"
														           Text="{asXaml:StringResource LogProfileEditorDialog.DataSourceProvider.ProVersionOnly}"/>
													</Grid>
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="Small"/>
									<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
										<Button Command="{Binding #window.SetDataSourceOptions}" 
										        Content="{asXaml:StringResource Common.Options.WithDialog}"
										        asControls:DialogElement.IsDialogItemInput="True">
											<Button.IsEnabled>
												<MultiBinding Converter="{x:Static BoolConverters.And}">
													<Binding Path="HasDataSourceOptions" ElementName="window"/>
													<MultiBinding Converter="{x:Static BoolConverters.Or}">
														<Binding Path="IsProVersionActivated" ElementName="window"/>
														<Binding Path="!SelectedItem.IsProVersionOnly" ElementName="dataSourceProviderComboBox"/>
													</MultiBinding>
												</MultiBinding>
											</Button.IsEnabled>
										</Button>
									</StackPanel>
								</StackPanel>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Allow multiple files -->
								<StackPanel Name="allowMultipleFilesPanel" HorizontalAlignment="Stretch" Orientation="Vertical">
									<asControls:DialogItem ItemSize="Small">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.AllowMultipleFiles}" asControls:DialogElement.TextRole="Label"/>
										<ToggleSwitch Name="allowMultipleFilesSwitch" asControls:DialogElement.IsDialogItemInput="True"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="Item"/>
								</StackPanel>

								<!-- Working directory requirement -->
								<StackPanel HorizontalAlignment="Stretch" IsEnabled="{Binding #window.IsWorkingDirectorySupported}" Orientation="Vertical">
									<asControls:DialogItem>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.WorkingDirectoryRequirement}" asControls:DialogElement.TextRole="Label"/>
										<asControls:EnumComboBox Name="workingDirPriorityComboBox" EnumType="{x:Type appLogProfiles:LogProfilePropertyRequirement}" asControls:DialogElement.IsDialogItemInput="True"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="Item"/>
								</StackPanel>

								<!-- Is administrator needed -->
								<StackPanel Name="isAdminNeededPanel" HorizontalAlignment="Stretch" Orientation="Vertical">
									<asControls:DialogItem ItemSize="Small">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IsAdministratorNeeded}" asControls:DialogElement.TextRole="Label"/>
										<ToggleSwitch Name="adminNeededSwitch" asControls:DialogElement.IsDialogItemInput="True"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="Item"/>
								</StackPanel>

								<!-- Is continuous reading -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IsContinuousReading}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.IsContinuousReading.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<ToggleSwitch Name="continuousReadingSwitch" asControls:DialogElement.IsDialogItemInput="True">
										<ia:Interaction.Behaviors>
											<iaCore:DataTriggerBehavior Binding="{Binding #dataSourceProviderComboBox.SelectedItem.Name, FallbackValue={}}" ComparisonCondition="Equal" Value="File">
												<iaCore:ChangePropertyAction PropertyName="IsChecked" Value="False"/>
												<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="False"/>
											</iaCore:DataTriggerBehavior>
											<iaCore:DataTriggerBehavior Binding="{Binding #dataSourceProviderComboBox.SelectedItem.Name, FallbackValue={}}" ComparisonCondition="NotEqual" Value="File">
												<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="True"/>
											</iaCore:DataTriggerBehavior>
										</ia:Interaction.Behaviors>
									</ToggleSwitch>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Restart reading delay -->
								<asControls:DialogItem ItemSize="Small">
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.RestartReadingDelay}" asControls:DialogElement.TextRole="Label"/>
									<abControls:IntegerTextBox Name="restartReadingDelayTextBox" asControls:DialogElement.IsDialogItemInput="True" IsEnabled="{Binding #continuousReadingSwitch.IsChecked}" IsNullValueAllowed="False" Maximum="3600000" Minimum="0"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Raw log level property -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.RawLogLevelPropertyName}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.RawLogLevelPropertyName.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<ComboBox Name="rawLogLevelPropertyComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{x:Static appLogs:Log.PropertyNames}">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<Grid ColumnDefinitions="*,Auto">
													<TextBlock Text="{Binding Converter={x:Static appConverters:LogPropertyNameConverter.Default}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
													<TextBlock Grid.Column="1" Opacity="0.3" Text="{Binding StringFormat={} ({0})}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
												</Grid>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Default log level -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.DefaultLogLevel}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.DefaultLogLevel.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<ComboBox Name="defaultLogLevelComboBox" asControls:DialogElement.IsDialogItemInput="True" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{Binding #window.LogLevels}">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<Grid ColumnDefinitions="Auto,*">
													<Border Classes="ListBoxItem_Icon" 
													        BorderBrush="{DynamicResource ComboBoxItemForeground}" 
													        BorderThickness="1"
													        CornerRadius="1"
													        Padding="1">
														<Border Background="{Binding Converter={x:Static appConverters:LogLevelBrushConverter.Background}}"/>
													</Border>
													<TextBlock Classes="ListBoxItem_TextBlock" Grid.Column="1" Text="{Binding Converter={x:Static appControls:LogProfileEditorDialog.LogLevelNameConverter}}" VerticalAlignment="Center"/>
												</Grid>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Log level map -->
								<StackPanel Name="logLevelMapForReadingContainer">
									<asControls:DialogItem>
										<StackPanel>
											<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogLevelMapForReading}" asControls:DialogElement.TextRole="Label"/>
											<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogLevelMapForReading.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
										</StackPanel>
										<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#logLevelMapForReadingListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
									<asControls:ListBox Name="logLevelMapForReadingListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #window.LogLevelMapEntriesForReading.Count}" ItemsSource="{Binding #window.LogLevelMapEntriesForReading}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
										<asControls:ListBox.ItemTemplate>
											<DataTemplate>
												<Grid ColumnDefinitions="*,*">
													<TextBlock Classes="ListBoxItem_TextBlock" Text="{Binding Key}"/>
													<Border Classes="InPlaceAction_Reserved"/>
													<DockPanel Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
														<StackPanel DockPanel.Dock="Right" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
															<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveLogLevelMapEntryCommand}" CommandParameter="{Binding $parent[ListBoxItem].DataContext}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
																<asControls:Image Classes="InPlaceAction_Icon">
																	<DrawingImage>
																		<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
																	</DrawingImage>
																</asControls:Image>
															</Button>
															<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditLogLevelMapEntryForReadingCommand}" CommandParameter="{Binding $parent[ListBoxItem].DataContext}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
																<asControls:Image Classes="InPlaceAction_Icon">
																	<DrawingImage>
																		<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
																	</DrawingImage>
																</asControls:Image>
															</Button>
														</StackPanel>
														<Grid ColumnDefinitions="Auto,*">
															<Border Classes="ListBoxItem_Icon" 
															        BorderBrush="{DynamicResource ComboBoxItemForeground}" 
															        BorderThickness="1"
															        CornerRadius="1"
															        Padding="1">
																<Border Background="{Binding Value, Converter={x:Static appConverters:LogLevelBrushConverter.Background}}" />
															</Border>
															<TextBlock Classes="ListBoxItem_TextBlock" Grid.Column="1" Text="{Binding Value, Converter={x:Static appControls:SessionView.LogLevelNameConverter}}"/>
														</Grid>
													</DockPanel>
												</Grid>
											</DataTemplate>
										</asControls:ListBox.ItemTemplate>
									</asControls:ListBox>
									<Separator IsVisible="{Binding #logLevelMapForReadingListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
									<Button Name="addLogLevelMapEntryForReadingButton" Command="{Binding #window.AddLogLevelMapEntryForReading}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</StackPanel>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Log patterns -->
								<StackPanel Name="logPatternsContainer">
									<asControls:DialogItem>
										<StackPanel>
											<WrapPanel>
												<TextBlock Name="logPatternsTextBlock" Text="{asXaml:StringResource LogProfileEditorDialog.LogPatterns}" asControls:DialogElement.TextRole="Label"/>
												<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.LogPatternsDocument}" ToolTip.Tip="{asXaml:StringResource Common.Help}">
													<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
												</Button>
											</WrapPanel>
											<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogPatterns.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
										</StackPanel>
										<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#logPatternListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
									<asControls:ListBox Name="logPatternListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" Grid.IsSharedSizeScope="True" IsVisible="{Binding #window.LogPatterns.Count}" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" ItemsSource="{Binding #window.LogPatterns}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
                            			<asControls:ListBox.ItemTemplate>
                            				<DataTemplate DataType="{x:Type appLogs:LogPattern}">
                            					<Grid RowDefinitions="Auto,*">
			                                        <Grid.ColumnDefinitions>
				                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Icon1"/>
				                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Icon2"/>
				                                        <ColumnDefinition Width="*"/>
				                                        <ColumnDefinition Width="Auto"/>
			                                        </Grid.ColumnDefinitions>
						                            <Image Classes="ListBoxItem_Icon" IsVisible="{Binding IsRepeatable}">
							                            <DrawingImage>
								                            <GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Repeatable}"/>
							                            </DrawingImage>
						                            </Image>
						                            <Image Classes="ListBoxItem_Icon" Grid.Column="1" IsVisible="{Binding IsSkippable}">
							                            <DrawingImage>
								                            <GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Skippable}"/>
							                            </DrawingImage>
						                            </Image>
			                                        <asControls:SyntaxHighlightingTextBlock DefinitionSet="{Binding #window.RegexSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" Grid.Column="2" Text="{Binding Regex}" TextTrimming="None" VerticalAlignment="Center"/>
			                                        <abControls:TextBlock FontSize="{StaticResource Double/LogProfileEditorDialog.LogPattern.Description.FontSize}" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Margin="{StaticResource Thickness/LogProfileEditorDialog.LogPattern.Description.Margin}" Opacity="{StaticResource Double/LogProfileEditorDialog.LogPattern.Description.Opacity}" Text="{Binding Description}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            						<Border Classes="InPlaceAction_Reserved"/>
		                                            <StackPanel Grid.Column="3" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
                            							<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveLogPatternCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
                            								<asControls:Image Classes="InPlaceAction_Icon">
                            									<DrawingImage>
                            										<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
                            									</DrawingImage>
                            								</asControls:Image>
                            							</Button>
                            							<Button Classes="InPlaceAction_Button" Command="{Binding #window.CopyLogPattern}" CommandParameter="{Binding $parent[ListBoxItem].DataContext}" ToolTip.Tip="{asXaml:StringResource Common.Copy}">
                            								<asControls:Image Classes="InPlaceAction_Icon">
                            									<DrawingImage>
                            										<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Copy.Outline}"/>
                            									</DrawingImage>
                            								</asControls:Image>
                            							</Button>
                            							<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditLogPatternCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
                            								<asControls:Image Classes="InPlaceAction_Icon">
                            									<DrawingImage>
                            										<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
                            									</DrawingImage>
                            								</asControls:Image>
                            							</Button>
                            						</StackPanel>
                            					</Grid>
                            				</DataTemplate>
                            			</asControls:ListBox.ItemTemplate>
		                            </asControls:ListBox>
									<Separator IsVisible="{Binding #logPatternListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
									<Button Name="addLogPatternButton" Command="{Binding #window.AddLogPattern}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</StackPanel>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Log pattern matching mode -->
								<asControls:DialogItem>
									<WrapPanel VerticalAlignment="Center">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogPatternMatchingMode}" asControls:DialogElement.TextRole="Label"/>
										<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.LogPatternMatchingModeDocument}" ToolTip.Tip="{asXaml:StringResource Common.Help}">
											<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
										</Button>
									</WrapPanel>
									<asControls:EnumComboBox Name="logPatternMatchingModeComboBox" EnumType="{x:Type appLogs:LogPatternMatchingMode}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Log string encoding for reading -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogStringEncodingForReading}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="logStringEncodingForReadingComboBox" EnumType="{x:Type appLogs:LogStringEncoding}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Timestamp encoding for reading -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampEncodingForReading}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="timestampEncodingForReadingComboBox" EnumType="{x:Type appLogs:LogTimestampEncoding}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Timestamp culture info for reading -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampCultureInfoForReading}" asControls:DialogElement.TextRole="Label"/>
									<appControls:CultureInfoComboBox Name="timestampCultureInfoForReadingComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Timestamp format for reading -->
								<asControls:DialogItem ItemSize="Small">
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampFormatsForReading}" asControls:DialogElement.TextRole="Label"/>
									<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#timestampFormatsForReadingListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
								<StackPanel>
									<ia:Interaction.Behaviors>
										<iaCore:DataTriggerBehavior Binding="{Binding #timestampEncodingForReadingComboBox.SelectedItem}" Value="Custom">
											<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="True"/>
										</iaCore:DataTriggerBehavior>
										<iaCore:DataTriggerBehavior Binding="{Binding #timestampEncodingForReadingComboBox.SelectedItem}" ComparisonCondition="NotEqual" Value="Custom">
											<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="False"/>
										</iaCore:DataTriggerBehavior>
									</ia:Interaction.Behaviors>
									<asControls:ListBox Name="timestampFormatsForReadingListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #window.TimestampFormatsForReading.Count}" ItemsSource="{Binding #window.TimestampFormatsForReading}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
										<asControls:ListBox.ItemTemplate>
											<DataTemplate>
												<Grid ColumnDefinitions="*,Auto">
													<asControls:SyntaxHighlightingTextBlock DefinitionSet="{Binding #window.DateTimeFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" Text="{Binding}" TextTrimming="None"/>
													<Border Classes="InPlaceAction_Reserved"/>
													<StackPanel Grid.Column="1" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveTimestampFormatForReadingCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditTimestampFormatForReadingCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
													</StackPanel>
												</Grid>
											</DataTemplate>
										</asControls:ListBox.ItemTemplate>
									</asControls:ListBox>
									<Separator IsVisible="{Binding #timestampFormatsForReadingListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
									<Button Command="{Binding #window.AddTimestampFormatForReading}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</StackPanel>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Time span encoding for reading -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanEncodingForReading}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanEncodingForReading.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<asControls:EnumComboBox Name="timeSpanEncodingForReadingComboBox" EnumType="{x:Type appLogs:LogTimeSpanEncoding}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Time span culture info for reading -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanCultureInfoForReading}" asControls:DialogElement.TextRole="Label"/>
									<appControls:CultureInfoComboBox Name="timeSpanCultureInfoForReadingComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Time span format for reading -->
								<asControls:DialogItem ItemSize="Small">
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanFormatsForReading}" asControls:DialogElement.TextRole="Label"/>
									<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#timeSpanFormatsForReadingListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
								<StackPanel>
									<ia:Interaction.Behaviors>
										<iaCore:DataTriggerBehavior Binding="{Binding #timeSpanEncodingForReadingComboBox.SelectedItem}" Value="Custom">
											<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="True"/>
										</iaCore:DataTriggerBehavior>
										<iaCore:DataTriggerBehavior Binding="{Binding #timeSpanEncodingForReadingComboBox.SelectedItem}" ComparisonCondition="NotEqual" Value="Custom">
											<iaCore:ChangePropertyAction PropertyName="IsEnabled" Value="False"/>
										</iaCore:DataTriggerBehavior>
									</ia:Interaction.Behaviors>
									<asControls:ListBox Name="timeSpanFormatsForReadingListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #window.TimeSpanFormatsForReading.Count}" ItemsSource="{Binding #window.TimeSpanFormatsForReading}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
										<asControls:ListBox.ItemTemplate>
											<DataTemplate>
												<Grid ColumnDefinitions="*,Auto">
													<asControls:SyntaxHighlightingTextBlock DefinitionSet="{Binding #window.TimeSpanFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" Text="{Binding}" TextTrimming="None"/>
													<Border Classes="InPlaceAction_Reserved"/>
													<StackPanel Grid.Column="1" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveTimeSpanFormatForReadingCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditTimeSpanFormatForReadingCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
													</StackPanel>
												</Grid>
											</DataTemplate>
										</asControls:ListBox.ItemTemplate>
									</asControls:ListBox>
									<Separator IsVisible="{Binding #timeSpanFormatsForReadingListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
									<Button Command="{Binding #window.AddTimeSpanFormatForReading}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</StackPanel>

							</StackPanel>
						</Border>
						<Separator asControls:DialogElement.SeparatorType="Large"/>
					</StackPanel>

					<!-- Log displaying -->
					<StackPanel Name="logDisplayingPanel">
						<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogDisplaying}" asControls:DialogElement.TextRole="ItemsGroupHeader"/>
						<Border Classes="Dialog_ItemsGroup_Container">
							<StackPanel>
						
								<!-- Visible log properties -->
								<StackPanel Name="visibleLogPropertiesContainer">
									<asControls:DialogItem>
										<StackPanel>
											<TextBlock Name="visiblePropertiesTextBlock" Text="{asXaml:StringResource LogProfileEditorDialog.VisibleLogProperties}" asControls:DialogElement.TextRole="Label"/>
											<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.VisibleLogProperties.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
										</StackPanel>
										<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#visibleLogPropertyListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
									</asControls:DialogItem>
									<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
									<asControls:ListBox Name="visibleLogPropertyListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" Grid.IsSharedSizeScope="True" IsVisible="{Binding #window.VisibleLogProperties.Count}" ItemsSource="{Binding #window.VisibleLogProperties}" ItemsPanel="{StaticResource ItemsPanelTemplate/StackPanel}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
										<asControls:ListBox.ItemTemplate>
											<DataTemplate DataType="{x:Type appLogProfiles:LogProperty}">
												<Grid>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" SharedSizeGroup="DisplayName"/>
														<ColumnDefinition Width="Auto" SharedSizeGroup="Name"/>
														<ColumnDefinition Width="*"/>
														<ColumnDefinition Width="Auto"/>
													</Grid.ColumnDefinitions>
													<StackPanel Orientation="Horizontal" IsVisible="{Binding #displayNameTextBlock.Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
														<TextBlock Name="displayNameTextBlock" Text="{Binding DisplayName, Converter={x:Static appConverters:LogPropertyNameConverter.Default}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
														<abControls:FormattedTextBlock Arg1="{Binding SecondaryDisplayName}" Format=" - {0}" IsVisible="{Binding SecondaryDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
														<abControls:FormattedTextBlock Arg1="{Binding Quantifier}" Format=" ({0})" IsVisible="{Binding Quantifier, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
													</StackPanel>
													<abControls:FormattedTextBlock Arg1="{asXaml:StringResource Common.Empty}" Format="({0})" IsVisible="{Binding #displayNameTextBlock.Text, Converter={x:Static StringConverters.IsNullOrEmpty}}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
													<Border Classes="InPlaceAction_Reserved"/>
													<abControls:FormattedTextBlock Arg1="{Binding Name}" Format="({0})" Grid.Column="1" Opacity="{StaticResource Double/LogProfileEditorDialog.VisibleLogPropertyListBox.Name.Opacity}" Margin="{StaticResource Thickness/LogProfileEditorDialog.VisibleLogPropertyListBox.Name.Margin}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
													<abControls:FormattedTextBlock Arg1="{Binding Width}" Format="[{0}]" Grid.Column="2" IsVisible="{Binding Width, Converter={x:Static ObjectConverters.IsNotNull}}" Margin="{StaticResource Thickness/LogProfileEditorDialog.VisibleLogPropertyListBox.Name.Margin}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
													<StackPanel Grid.Column="3" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveVisibleLogPropertyCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditVisibleLogPropertyCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
													</StackPanel>
												</Grid>
											</DataTemplate>
										</asControls:ListBox.ItemTemplate>
									</asControls:ListBox>
									<Separator IsVisible="{Binding #visibleLogPropertyListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
									<Button Name="addVisibleLogPropertyButton" Command="{Binding #window.AddVisibleLogProperty}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</StackPanel>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Timestamp format for displaying -->
								<asControls:DialogItem ItemSize="Small">
									<WrapPanel VerticalAlignment="Center">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampFormatForDisplaying}" asControls:DialogElement.TextRole="Label"/>
										<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.DateTimeFormatReference}" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.FormatDescription}">
											<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
										</Button>
									</WrapPanel>
									<asControls:SyntaxHighlightingTextBox Name="timestampFormatForDisplayingTextBox" DefinitionSet="{Binding #window.DateTimeFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource Common.None}"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Time span format for displaying -->
								<asControls:DialogItem ItemSize="Small">
									<WrapPanel VerticalAlignment="Center">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanFormatForDisplaying}" asControls:DialogElement.TextRole="Label"/>
										<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.TimeSpanFormatReference}" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.FormatDescription}">
											<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
										</Button>
									</WrapPanel>
									<asControls:SyntaxHighlightingTextBox Name="timeSpanFormatForDisplayingTextBox" DefinitionSet="{Binding #window.TimeSpanFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource Common.None}"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Color indicator -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.ColorIndicator}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.ColorIndicator.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<asControls:EnumComboBox Name="colorIndicatorComboBox" EnumType="{x:Type appLogProfiles:LogColorIndicator}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Sort key -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.SortKey}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="sortKeyComboBox" EnumType="{x:Type appLogProfiles:LogSortKey}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Sort direction -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.SortDirection}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="sortDirectionComboBox" EnumType="{x:Type app:SortDirection}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Timestamp category granularity -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampCategoryGranularity}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="timestampCategoryGranularityComboBox" EnumType="{x:Type appCategorizing:TimestampDisplayableLogCategoryGranularity}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>

							</StackPanel>
						</Border>
						<Separator asControls:DialogElement.SeparatorType="Large"/>
					</StackPanel>

					<!-- Log writing -->
					<StackPanel Name="logWritingPanel">
						<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogWriting}" asControls:DialogElement.TextRole="ItemsGroupHeader"/>
						<Border Classes="Dialog_ItemsGroup_Container">
							<StackPanel>
						
								<!-- Log writing formats -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogWritingFormats}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogWritingFormats.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#logWritingFormatListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
								<asControls:ListBox Name="logWritingFormatListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #window.LogWritingFormats.Count}" ItemsSource="{Binding #window.LogWritingFormats}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
									<asControls:ListBox.ItemTemplate>
										<DataTemplate>
											<Grid ColumnDefinitions="*,Auto">
												<asControls:SyntaxHighlightingTextBlock DefinitionSet="{Binding #window.LogWritingFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" Text="{Binding}" TextWrapping="NoWrap" TextTrimming="None"/>
												<Border Classes="InPlaceAction_Reserved"/>
												<StackPanel Grid.Column="1" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
													<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveLogWritingFormatCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
														<asControls:Image Classes="InPlaceAction_Icon">
															<DrawingImage>
																<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
															</DrawingImage>
														</asControls:Image>
													</Button>
													<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditLogWritingFormatCommand}" CommandParameter="{Binding $parent[ListBoxItem]}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
														<asControls:Image Classes="InPlaceAction_Icon">
															<DrawingImage>
																<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
															</DrawingImage>
														</asControls:Image>
													</Button>
												</StackPanel>
											</Grid>
										</DataTemplate>
									</asControls:ListBox.ItemTemplate>
								</asControls:ListBox>
								<Separator IsVisible="{Binding #logWritingFormatListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
								<Button Command="{Binding #window.AddLogWritingFormat}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Log level map -->
								<asControls:DialogItem>
									<StackPanel>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogLevelMapForWriting}" asControls:DialogElement.TextRole="Label"/>
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogLevelMapForWriting.Description}" asControls:DialogElement.TextRole="DescriptionBelowLabel"/>
									</StackPanel>
									<TextBlock HorizontalAlignment="Right" IsVisible="{Binding !#logLevelMapForWritingListBox.IsVisible}" Text="{asXaml:StringResource Common.None}" asControls:DialogElement.TextRole="Default"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="InnerItem"/>
								<asControls:ListBox Name="logLevelMapForWritingListBox" DoubleClickOnItem="OnListBoxDoubleClickOnItem" asControls:DialogElement.IsDialogItemInput="True" IsVisible="{Binding #window.LogLevelMapEntriesForWriting.Count}" ItemsSource="{Binding #window.LogLevelMapEntriesForWriting}" LostFocus="OnListBoxLostFocus" SelectionChanged="OnListBoxSelectionChanged">
									<asControls:ListBox.ItemTemplate>
										<DataTemplate>
											<Grid ColumnDefinitions="*,*">
												<Grid ColumnDefinitions="Auto,*">
													<Border Classes="ListBoxItem_Icon" 
													        BorderBrush="{DynamicResource ComboBoxItemForeground}" 
													        BorderThickness="1"
													        CornerRadius="1"
													        Padding="1">
														<Border Background="{Binding Key, Converter={x:Static appConverters:LogLevelBrushConverter.Background}}" />
													</Border>
													<TextBlock Classes="ListBoxItem_TextBlock" Grid.Column="1" Text="{Binding Key, Converter={x:Static appConverters:EnumConverters.LogLevel}}"/>
												</Grid>
												<Border Classes="InPlaceAction_Reserved"/>
												<DockPanel Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
													<StackPanel DockPanel.Dock="Right" IsVisible="{Binding $parent[ListBoxItem].IsPointerOver}" Orientation="Horizontal">
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.RemoveLogLevelMapEntryCommand}" CommandParameter="{Binding $parent[ListBoxItem].DataContext}" ToolTip.Tip="{asXaml:StringResource Common.Delete}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Delete.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
														<Button Classes="InPlaceAction_Button" Command="{Binding #window.EditLogLevelMapEntryForWritingCommand}" CommandParameter="{Binding $parent[ListBoxItem].DataContext}" ToolTip.Tip="{asXaml:StringResource Common.Edit}">
															<asControls:Image Classes="InPlaceAction_Icon">
																<DrawingImage>
																	<GeometryDrawing Brush="{Binding $parent[ListBoxItem].Foreground}" Geometry="{StaticResource Geometry/Icon.Edit.Outline}"/>
																</DrawingImage>
															</asControls:Image>
														</Button>
													</StackPanel>
													<TextBlock Classes="ListBoxItem_TextBlock" Text="{Binding Value}"/>
												</DockPanel>
											</Grid>
										</DataTemplate>
									</asControls:ListBox.ItemTemplate>
								</asControls:ListBox>
								<Separator IsVisible="{Binding #logLevelMapForWritingListBox.IsVisible}" asControls:DialogElement.SeparatorType="Small"/>
								<Button Command="{Binding #window.AddLogLevelMapEntryForWriting}" Content="{asXaml:StringResource Common.Add.WithDialog}" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Log string format for writing -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.LogStringEncodingForWriting}" asControls:DialogElement.TextRole="Label"/>
									<asControls:EnumComboBox Name="logStringEncodingForWritingComboBox"  EnumType="{x:Type appLogs:LogStringEncoding}" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Timestamp culture info for writing -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampCultureInfoForWriting}" asControls:DialogElement.TextRole="Label"/>
									<appControls:CultureInfoComboBox Name="timestampCultureInfoForWritingComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Timestamp format for writing -->
								<asControls:DialogItem ItemSize="Small">
									<WrapPanel VerticalAlignment="Center">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimestampFormatForWriting}" asControls:DialogElement.TextRole="Label"/>
										<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.DateTimeFormatReference}" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.FormatDescription}">
											<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
										</Button>
									</WrapPanel>
									<asControls:SyntaxHighlightingTextBox Name="timestampFormatForWritingTextBox" DefinitionSet="{Binding #window.DateTimeFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource LogProfileEditorDialog.TimestampFormatForWriting.Watermark}"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>
								
								<!-- Time span culture info for writing -->
								<asControls:DialogItem>
									<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanCultureInfoForWriting}" asControls:DialogElement.TextRole="Label"/>
									<appControls:CultureInfoComboBox Name="timeSpanCultureInfoForWritingComboBox" HorizontalAlignment="Right" asControls:DialogElement.IsDialogItemInput="True"/>
								</asControls:DialogItem>
								<Separator asControls:DialogElement.SeparatorType="Item"/>

								<!-- Time span format for writing -->
								<asControls:DialogItem ItemSize="Small">
									<WrapPanel VerticalAlignment="Center">
										<TextBlock Text="{asXaml:StringResource LogProfileEditorDialog.TimeSpanFormatForWriting}" asControls:DialogElement.TextRole="Label"/>
										<Button asControls:DialogElement.ButtonRole="ShowInformation" Command="{x:Static app:Utility.OpenLinkCommand}" CommandParameter="{x:Static app:Uris.TimeSpanFormatReference}" ToolTip.Tip="{asXaml:StringResource LogProfileEditorDialog.FormatDescription}">
											<Image Classes="Icon" Source="{DynamicResource Image/Icon.Question.Outline}"/>
										</Button>
									</WrapPanel>
									<asControls:SyntaxHighlightingTextBox Name="timeSpanFormatForWritingTextBox" DefinitionSet="{Binding #window.TimeSpanFormatSyntaxHighlightingDefinitionSet}" FontFamily="{Binding PatternFontFamily, Source={x:Static appControls:ControlFonts.Default}}" asControls:DialogElement.IsDialogItemInput="True" MaxLength="256" Watermark="{asXaml:StringResource LogProfileEditorDialog.TimeSpanFormatForWriting.Watermark}"/>
								</asControls:DialogItem>
								
							</StackPanel>
						</Border>
					</StackPanel>

				</StackPanel>
			</ScrollViewer>
		</Panel>
		
	</DockPanel>
  
</Window>
